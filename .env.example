# L3 종합 평가 LLM. 옵션: jeonbuk | gemini | claude
LLM_PROVIDER=jeonbuk

# 전북AI 학생 API (OpenAI 호환, 키는 절대 커밋 금지)
JEONBUK_API_KEY=
JEONBUK_BASE_URL=https://ai.jb.go.kr/student-api/v1
JEONBUK_CHAT_MODEL=gemma-4-31b-turbo

# STT 공급자. 옵션: jeonbuk | local
STT_PROVIDER=jeonbuk
JEONBUK_STT_MODEL=cohere-transcribe

# Gemini (https://aistudio.google.com/apikey — 카드 등록 불필요, 즉시 발급)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Claude (LLM_PROVIDER=claude 일 때만 필요)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# 로컬 STT fallback (STT_PROVIDER=local)
WHISPER_MODEL=medium
