# L3 종합 평가 LLM. default=gemini (무료 한도 큼). 다른 옵션: claude
LLM_PROVIDER=gemini

# Gemini (https://aistudio.google.com/apikey — 카드 등록 불필요, 즉시 발급)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Claude (LLM_PROVIDER=claude 일 때만 필요)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# v1.5 종합 트랙 — cohere-transcribe 재전사
COHERE_API_KEY=
